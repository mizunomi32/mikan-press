# =============================================================================
# mikan-press 環境変数設定
# =============================================================================
#
# このファイルをコピーして .env ファイルを作成してください
#   cp .env.example .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# APIキー（少なくとも1つ必須）
# -----------------------------------------------------------------------------
# 使用するプロバイダーのAPIキーを設定してください
# 複数設定可能で、モデル設定に応じて自動的に選択されます

# OpenAI API キー（GPT-4oなどを使用する場合）
OPENAI_API_KEY=

# Google AI API キー（Geminiなどを使用する場合）
GOOGLE_API_KEY=

# OpenRouter API キー（Claude、Llama などを使用する場合）
OPENROUTER_API_KEY=

# ZHIPU AI API キー（GLM-4、GLM-5などを使用する場合）
ZHIPU_API_KEY=

# GLM Coding Plan を使う場合はエンドポイントを変更（任意）
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4

# -----------------------------------------------------------------------------
# エージェントモデル設定（任意）
# -----------------------------------------------------------------------------
# 各エージェントが使用するモデルを provider/model 形式で指定
# 形式: openai/gpt-4o | gemini/gemini-2.5-flash | openrouter/anthropic/claude-3.5-sonnet | glm/glm-4-plus
#
# 未設定の場合はデフォルト値（openai/gpt-4o）が使用されます
#
# 注意: RESEARCHER_MODELにはツール呼び出し(Function Calling)対応モデルを使用してください
# 対応例: openai/gpt-4o, gemini/gemini-2.5-flash, glm/glm-5, openrouter/anthropic/claude-3.5-sonnet

# RESEARCHER_MODEL=gemini/gemini-2.5-flash
# PLANNER_MODEL=openai/gpt-4o
# WRITER_MODEL=openai/gpt-4o
# EDITOR_MODEL=openai/gpt-4o
# REVIEWER_MODEL=openai/gpt-4o

# -----------------------------------------------------------------------------
# ログレベル（任意）
# -----------------------------------------------------------------------------
# デフォルト: info
# 指定可能な値: error | warn | info | debug

# LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# リトライ・レビュー設定（任意）
# -----------------------------------------------------------------------------
# 各エージェントの最大自己リトライ回数（デフォルト: 3）
# MAX_RETRIES_PER_AGENT=3

# 最大レビュー回数（デフォルト: 3）
# MAX_REVIEWS=3
