OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
ZHIPU_API_KEY=
# GLM Coding Plan を使う場合はエンドポイントを変更
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4

# エージェントごとのモデル指定 (provider/model 形式)
# 例: openai/gpt-4o, gemini/gemini-2.5-flash, openrouter/anthropic/claude-3.5-sonnet, glm/glm-4-plus
RESEARCHER_MODEL=gemini/gemini-2.5-flash
PLANNER_MODEL=openai/gpt-4o
WRITER_MODEL=openai/gpt-4o
EDITOR_MODEL=openai/gpt-4o
REVIEWER_MODEL=openai/gpt-4o

# ログレベル (error | warn | info | debug) デフォルト: info
# LOG_LEVEL=debug
