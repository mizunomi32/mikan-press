# === プロバイダー接続情報 ===

# Zhipu AI (GLM)
# APIキー: https://open.bigmodel.cn/ から取得
ZHIPU_API_KEY=your_zhipu_api_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4  # オプション
# ZHIPU_MODEL=glm-4-flash  # レガシー: *_MODEL 未指定時のフォールバック

# Google AI (Gemini)
# APIキー: https://aistudio.google.com/ から取得
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI（オプション）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # オプション

# OpenRouter（オプション）
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# === エージェントごとのモデル指定（provider/model 形式） ===
# 対応プロバイダー: google, zhipu, openai, openrouter

# RESEARCH_MODEL=google/gemini-2.5-flash-lite    # デフォルト
# PLAN_MODEL=zhipu/glm-5                  # デフォルト
# WRITER_MODEL=zhipu/glm-5                 # デフォルト
# EDITOR_MODEL=zhipu/glm-5                 # デフォルト
# REVIEW_MODEL=zhipu/glm-5                 # デフォルト

# 使用例:
# WRITER_MODEL=openai/gpt-4o
# EDITOR_MODEL=openrouter/anthropic/claude-sonnet-4
# REVIEW_MODEL=google/gemini-2.5-pro

# === オプション設定 ===
ARTICLE_LANGUAGE=ja          # 出力言語 (ja / en)
MAX_ARTICLE_LENGTH=6000      # 最大文字数（目安）
# SKIP_RESEARCH=true         # リサーチをスキップ（GOOGLE_API_KEY 不要になる）
