{
  "name": "mikan-press",
  "version": "0.1.0",
  "description": "LangChain.js + LangGraph.js による記事執筆AIエージェント",
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@langchain/community": "^1.1.17",
    "@langchain/core": "^1.1.27",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/openai": "^1.2.9",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "langchain": "^1.2.25",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
